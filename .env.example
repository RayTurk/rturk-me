NEXT_PUBLIC_WORDPRESS_URL=https://cms.rturk.me
NEXT_PUBLIC_WP_HOSTNAME=cms.rturk.me
# Note: WPGraphQL uses query-string routing, not pretty permalinks
WORDPRESS_GRAPHQL_ENDPOINT=https://cms.rturk.me/?graphql
NEXT_PUBLIC_SITE_URL=https://rturk.me
REVALIDATION_SECRET=change-me-32-chars-minimum

# Codegen only — WP Application Password for schema introspection.
# Generate via WP Admin → Users → Profile → Application Passwords.
# Then run: echo -n "username:app_password" | base64
# WP_CODEGEN_BASIC_AUTH=<base64 of username:app_password>

# Analytics (loaded only after cookie consent)
NEXT_PUBLIC_GTM_ID=GTM-WSTH9JTX
